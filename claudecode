<!DOCTYPE html>

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Likha | Tile Artisan</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ivory:     #f5f2ed;
      --warm-white:#faf8f5;
      --stone:     #c8bfb0;
      --sand:      #e2d9cc;
      --charcoal:  #1e1c1a;
      --ink:       #2e2b27;
      --muted:     #8a837a;
      --accent:    #7a6a58;
      --gold:      #b89d7a;
      --serif:     'Cormorant Garamond', Georgia, serif;
      --sans:      'Jost', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background-color: var(--warm-white);
      color: var(--ink);
      font-family: var(--sans);
      font-weight: 300;
      overflow-x: hidden;
      cursor: none;
    }

    /* Custom cursor */
    .cursor {
      width: 8px; height: 8px;
      background: var(--charcoal);
      border-radius: 50%;
      position: fixed;
      top: 0; left: 0;
      pointer-events: none;
      z-index: 9999;
      transition: transform 0.15s ease;
    }
    .cursor-ring {
      width: 36px; height: 36px;
      border: 1px solid var(--accent);
      border-radius: 50%;
      position: fixed;
      top: 0; left: 0;
      pointer-events: none;
      z-index: 9998;
      transition: transform 0.35s ease, opacity 0.2s ease;
      opacity: 0.6;
    }

    /* ── TILE TEXTURE OVERLAY ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(200,191,176,0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(200,191,176,0.08) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 0;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 2rem 4rem;
      background: transparent;
      transition: background 0.4s ease, padding 0.4s ease;
    }
    nav.scrolled {
      background: rgba(250,248,245,0.92);
      backdrop-filter: blur(10px);
      padding: 1.2rem 4rem;
      border-bottom: 1px solid var(--sand);
    }
    .nav-logo {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 400;
      letter-spacing: 0.04em;
      color: var(--charcoal);
      text-decoration: none;
    }
    .nav-logo span {
      font-weight: 300;
      color: var(--muted);
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      display: block;
      font-family: var(--sans);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      text-decoration: none;
      color: var(--ink);
      font-size: 0.72rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 300;
      position: relative;
      transition: color 0.3s;
    }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -3px; left: 0;
      width: 0; height: 1px;
      background: var(--gold);
      transition: width 0.35s ease;
    }
    .nav-links a:hover { color: var(--accent); }
    .nav-links a:hover::after { width: 100%; }

    /* ── HERO ── */
    #hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 0 4rem;
      overflow: hidden;
      z-index: 1;
    }
    .hero-content {
      max-width: 700px;
      opacity: 0;
      transform: translateY(30px);
      animation: fadeUp 1.2s ease 0.3s forwards;
    }
    .hero-eyebrow {
      font-family: var(--sans);
      font-size: 0.68rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
      font-weight: 300;
    }
    .hero-title {
      font-family: var(--serif);
      font-size: clamp(3.5rem, 7vw, 6.5rem);
      font-weight: 300;
      line-height: 1.05;
      color: var(--charcoal);
      margin-bottom: 2rem;
    }
    .hero-title em {
      font-style: italic;
      color: var(--accent);
    }
    .hero-subtitle {
      font-size: 0.9rem;
      line-height: 1.9;
      color: var(--muted);
      max-width: 480px;
      margin-bottom: 3rem;
      letter-spacing: 0.04em;
    }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 1rem;
      text-decoration: none;
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--charcoal);
      font-weight: 400;
      border-bottom: 1px solid var(--gold);
      padding-bottom: 0.3rem;
      transition: gap 0.3s, color 0.3s;
    }
    .hero-cta:hover { gap: 1.5rem; color: var(--accent); }
    .hero-cta::after { content: '→'; }

    /* Floating tile mosaic */
    .hero-mosaic {
      position: absolute;
      right: -2rem;
      top: 50%;
      transform: translateY(-50%);
      width: 480px;
      height: 560px;
      opacity: 0;
      animation: fadeIn 1.5s ease 0.8s forwards;
    }
    .tile-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(5, 1fr);
      gap: 6px;
      width: 100%;
      height: 100%;
      transform: rotate(-4deg);
    }
    .tile {
      border-radius: 2px;
      transition: transform 0.4s ease, opacity 0.3s;
    }
    .tile:hover { transform: scale(1.05); }
    .t1  { background: var(--charcoal); }
    .t2  { background: var(--stone); }
    .t3  { background: #d4c4a8; }
    .t4  { background: var(--ivory); border: 1px solid var(--sand); }
    .t5  { background: var(--gold); opacity: 0.7; }
    .t6  { background: #3d3530; }
    .t7  { background: var(--sand); }
    .t8  { background: #a09080; }
    .t9  { background: var(--warm-white); border: 1px solid var(--sand); }
    .t10 { background: #5a4f44; }
    .t11 { background: var(--stone); opacity: 0.6; }
    .t12 { background: var(--charcoal); opacity: 0.8; }
    .t13 { background: #e8ddd0; }
    .t14 { background: var(--gold); opacity: 0.5; }
    .t15 { background: #2a2420; }
    .t16 { background: var(--sand); }
    .t17 { background: #c4b59a; }
    .t18 { background: var(--accent); opacity: 0.6; }
    .t19 { background: var(--ivory); border: 1px solid var(--stone); }
    .t20 { background: var(--charcoal); }
    .tile.tall { grid-row: span 2; }
    .tile.wide { grid-column: span 2; }

    /* ── SECTION BASE ── */
    section {
      position: relative;
      z-index: 1;
      padding: 7rem 4rem;
    }
    .section-label {
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 300;
      margin-bottom: 1.2rem;
    }
    .section-heading {
      font-family: var(--serif);
      font-size: clamp(2.2rem, 4vw, 3.5rem);
      font-weight: 300;
      color: var(--charcoal);
      line-height: 1.2;
      margin-bottom: 1.5rem;
    }
    .section-heading em { font-style: italic; color: var(--accent); }

    /* ── ABOUT ── */
    #about {
      background: var(--ivory);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
    }
    .about-text p {
      font-size: 0.92rem;
      line-height: 2;
      color: var(--muted);
      margin-bottom: 1.4rem;
      letter-spacing: 0.03em;
    }
    .about-visual {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(3, 120px);
      gap: 8px;
    }
    .av1 { background: var(--charcoal); border-radius: 3px; grid-row: span 2; }
    .av2 { background: var(--stone); border-radius: 3px; }
    .av3 { background: var(--gold); opacity: 0.6; border-radius: 3px; }
    .av4 { background: #d4c4a8; border-radius: 3px; grid-column: span 2; }
    .av5 { background: var(--accent); opacity: 0.5; border-radius: 3px; }
    .av6 { background: var(--sand); border-radius: 3px; }
    .av7 { background: #3d3530; border-radius: 3px; }

    /* ── SERVICES ── */
    #services { background: var(--warm-white); }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      margin-top: 3.5rem;
    }
    .service-card {
      padding: 2.5rem 2rem;
      background: var(--ivory);
      border: 1px solid var(--sand);
      transition: background 0.4s ease, transform 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    .service-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--gold), var(--accent));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.4s ease;
    }
    .service-card:hover { background: var(--charcoal); transform: translateY(-4px); }
    .service-card:hover .service-num,
    .service-card:hover .service-title,
    .service-card:hover .service-desc { color: var(--ivory); }
    .service-card:hover::before { transform: scaleX(1); }
    .service-num {
      font-family: var(--serif);
      font-size: 3rem;
      font-weight: 300;
      color: var(--sand);
      line-height: 1;
      margin-bottom: 1rem;
      transition: color 0.4s;
    }
    .service-title {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 400;
      color: var(--charcoal);
      margin-bottom: 0.8rem;
      transition: color 0.4s;
    }
    .service-desc {
      font-size: 0.8rem;
      line-height: 1.85;
      color: var(--muted);
      transition: color 0.4s;
    }
    .service-card:hover .service-desc { color: var(--stone); }

    /* ── PHILOSOPHY ── */
    #philosophy {
      background: var(--charcoal);
      text-align: center;
      padding: 8rem 4rem;
    }
    #philosophy .section-label { color: var(--gold); }
    .philosophy-quote {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      font-weight: 300;
      color: var(--ivory);
      max-width: 820px;
      margin: 0 auto 2rem;
      line-height: 1.4;
      font-style: italic;
    }
    .philosophy-attr {
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--stone);
      font-weight: 300;
    }
    /* decorative tile strip */
    .tile-strip {
      display: flex;
      gap: 3px;
      margin: 3.5rem auto;
      max-width: 400px;
      justify-content: center;
    }
    .strip-tile {
      height: 4px;
      flex: 1;
      border-radius: 1px;
    }

    /* ── PROCESS ── */
    #process { background: var(--ivory); }
    .process-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      margin-top: 3.5rem;
      position: relative;
    }
    .process-steps::before {
      content: '';
      position: absolute;
      top: 28px; left: 14%;
      width: 72%;
      height: 1px;
      background: var(--sand);
    }
    .step {
      padding: 0 1.5rem;
      text-align: center;
    }
    .step-dot {
      width: 56px; height: 56px;
      border: 1px solid var(--gold);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
      background: var(--ivory);
      position: relative;
      z-index: 1;
    }
    .step-dot span {
      font-family: var(--serif);
      font-size: 1.1rem;
      font-weight: 300;
      color: var(--accent);
    }
    .step-title {
      font-family: var(--serif);
      font-size: 1.05rem;
      font-weight: 400;
      color: var(--charcoal);
      margin-bottom: 0.6rem;
    }
    .step-desc {
      font-size: 0.78rem;
      line-height: 1.8;
      color: var(--muted);
    }

    /* ── COLLECTIONS ── */
    #collections { background: var(--warm-white); }
    .collections-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto auto;
      gap: 2px;
      margin-top: 3.5rem;
    }
    .collection-card {
      position: relative;
      overflow: hidden;
      cursor: none;
    }
    .collection-card.featured { grid-column: span 2; }
    .coll-bg {
      height: 340px;
      display: flex;
      align-items: flex-end;
      padding: 2rem;
      position: relative;
      transition: transform 0.6s ease;
    }
    .collection-card:hover .coll-bg { transform: scale(1.03); }
    .c1 .coll-bg { background: linear-gradient(145deg, var(--charcoal) 0%, #3d3530 100%); }
    .c2 .coll-bg { background: linear-gradient(145deg, #c4b59a 0%, var(--stone) 100%); }
    .c3 .coll-bg { background: linear-gradient(145deg, var(--accent) 0%, #5a4f44 100%); }
    .c4 .coll-bg { background: linear-gradient(145deg, #2a2420 0%, #4a3f35 100%); }
    .c5 .coll-bg { background: linear-gradient(145deg, var(--sand) 0%, var(--ivory) 100%); }

    /* Tile pattern overlays */
    .c1 .coll-bg::before, .c2 .coll-bg::before, .c3 .coll-bg::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    .coll-info {
      position: relative;
      z-index: 1;
    }
    .coll-name {
      font-family: var(--serif);
      font-size: 1.6rem;
      font-weight: 300;
      color: var(--ivory);
      margin-bottom: 0.3rem;
    }
    .c5 .coll-name { color: var(--charcoal); }
    .coll-tag {
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 300;
    }

    /* ── CONTACT ── */
    #contact {
      background: var(--charcoal);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: start;
      padding: 7rem 4rem;
    }
    #contact .section-label { color: var(--gold); }
    #contact .section-heading { color: var(--ivory); }
    .contact-text {
      font-size: 0.88rem;
      line-height: 2;
      color: var(--stone);
      margin-bottom: 2.5rem;
    }
    .contact-detail {
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
    }
    .contact-item {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .contact-item-label {
      font-size: 0.62rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 300;
    }
    .contact-item-value {
      font-family: var(--serif);
      font-size: 1rem;
      color: var(--ivory);
      font-weight: 300;
    }
    .contact-item-value a {
      color: var(--ivory);
      text-decoration: none;
      border-bottom: 1px solid var(--accent);
      transition: color 0.3s;
    }
    .contact-item-value a:hover { color: var(--gold); }

    /* Form */
    .contact-form { display: flex; flex-direction: column; gap: 1.2rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
    .form-group label {
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 300;
    }
    .form-group input,
    .form-group textarea,
    .form-group select {
      background: transparent;
      border: none;
      border-bottom: 1px solid #4a4540;
      padding: 0.8rem 0;
      color: var(--ivory);
      font-family: var(--sans);
      font-size: 0.88rem;
      font-weight: 300;
      outline: none;
      transition: border-color 0.3s;
      appearance: none;
      -webkit-appearance: none;
    }
    .form-group input::placeholder,
    .form-group textarea::placeholder { color: #5a5550; }
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus { border-bottom-color: var(--gold); }
    .form-group select option { background: var(--charcoal); color: var(--ivory); }
    .form-group textarea { resize: none; height: 100px; }
    .form-submit {
      margin-top: 0.5rem;
      padding: 1rem 2.5rem;
      background: transparent;
      border: 1px solid var(--gold);
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.68rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      cursor: none;
      transition: background 0.4s, color 0.4s;
      font-weight: 300;
    }
    .form-submit:hover { background: var(--gold); color: var(--charcoal); }

    /* ── FOOTER ── */
    footer {
      background: #161412;
      padding: 2.5rem 4rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid #2a2420;
      z-index: 1;
      position: relative;
    }
    .footer-logo {
      font-family: var(--serif);
      font-size: 1.1rem;
      color: var(--stone);
      font-weight: 300;
    }
    .footer-copy {
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      color: #4a4540;
      text-transform: uppercase;
    }
    .footer-social {
      display: flex;
      gap: 1.5rem;
    }
    .footer-social a {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #4a4540;
      text-decoration: none;
      transition: color 0.3s;
    }
    .footer-social a:hover { color: var(--gold); }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      to { opacity: 1; }
    }

    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      nav { padding: 1.5rem 2rem; }
      nav.scrolled { padding: 1rem 2rem; }
      .nav-links { display: none; }
      #hero { padding: 0 2rem; }
      .hero-mosaic { display: none; }
      #about { grid-template-columns: 1fr; gap: 3rem; padding: 4rem 2rem; }
      #services, #collections, #process { padding: 4rem 2rem; }
      .services-grid { grid-template-columns: 1fr; }
      .collections-grid { grid-template-columns: 1fr; }
      .collection-card.featured { grid-column: span 1; }
      #contact { grid-template-columns: 1fr; gap: 3rem; padding: 4rem 2rem; }
      .process-steps { grid-template-columns: 1fr 1fr; gap: 2rem; }
      .process-steps::before { display: none; }
      footer { flex-direction: column; gap: 1rem; text-align: center; padding: 2rem; }
      #philosophy { padding: 5rem 2rem; }
      section { padding: 4rem 2rem; }
    }
  </style>

</head>
